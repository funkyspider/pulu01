<Window x:Class="Savant.Pulse.Utility.WPF.Client.PULU01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PULU01 - Donation Hold Clearing Utility" Height="600" Width="800"
        MinHeight="500" MinWidth="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="PULU01 - Donation Hold Clearing Utility" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        
        <!-- File Selection -->
        <GroupBox Grid.Row="1" Header="File Selection" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathTextBox" Grid.Column="0" Margin="0,0,10,0" 
                         IsReadOnly="True" Background="LightGray"/>
                <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse..." 
                        Width="80" Click="BrowseButton_Click"/>
            </Grid>
        </GroupBox>
        
        <!-- Processing Options -->
        <GroupBox Grid.Row="2" Header="Processing Options" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Thread Count:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="ThreadCountTextBox" Grid.Column="1" Width="60" Text="5" 
                         VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="(1-50 threads. More threads = faster processing)" 
                           VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic" Foreground="Gray"/>
            </Grid>
        </GroupBox>
        
        <!-- Progress and Log -->
        <GroupBox Grid.Row="3" Header="Progress and Status">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Progress Bar -->
                <ProgressBar x:Name="MainProgressBar" Grid.Row="0" Height="25" Margin="0,0,0,10"/>
                
                <!-- Statistics -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProcessedCountLabel" Grid.Column="0" Text="Processed: 0" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SuccessCountLabel" Grid.Column="1" Text="Success: 0" HorizontalAlignment="Center" Foreground="Green"/>
                    <TextBlock x:Name="FailedCountLabel" Grid.Column="2" Text="Failed: 0" HorizontalAlignment="Center" Foreground="Red"/>
                    <TextBlock x:Name="SkippedCountLabel" Grid.Column="3" Text="Skipped: 0" HorizontalAlignment="Center" Foreground="Orange"/>
                </Grid>
                
                <!-- Status Text -->
                <TextBlock x:Name="StatusLabel" Grid.Row="2" Text="Ready to process..." Margin="0,0,0,10" FontWeight="Bold"/>
                
                <!-- Log Output -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogTextBox" IsReadOnly="True" Background="Black" Foreground="LightGreen" 
                             FontFamily="Consolas" FontSize="12" AcceptsReturn="True" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </GroupBox>
        
        <!-- Control Buttons -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="StartButton" Grid.Column="1" Content="Start Processing" 
                    Width="120" Height="35" Margin="0,0,10,0" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Grid.Column="2" Content="Stop" 
                    Width="80" Height="35" IsEnabled="False" Click="StopButton_Click"/>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="5" Margin="0,10,0,0">
            <TextBlock x:Name="StatusBarText" Text="Ready"/>
        </StatusBar>
    </Grid>
</Window>